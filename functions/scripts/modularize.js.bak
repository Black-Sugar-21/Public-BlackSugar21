// ============================================================  
// 10. coach.js — the big one
// Coach infrastructure (L3079-3536) + learning (L3375-3536) + coachRAG (L3699-3812) 
// + dateCoachChat (L3813-5385) + getCoachHistory (L5386-5441) + deleteCoachMessage (L5442-5481)
// + getRealtimeCoachTips (L7548-7696)
// ============================================================
(() => {
  const header = `'use strict';
const { onCall } = require('firebase-functions/v2/https');
const admin = require('firebase-admin');
const { GoogleGenerativeAI, geminiApiKey, placesApiKey, AI_MODEL_NAME, AI_MODEL_LITE, getLanguageInstruction, normalizeCategory, categoryEmojiMap, parseGeminiJsonResponse } = require('./shared');
const { reverseGeocode, forwardGeocode, haversineDistanceKm } = require('./geo');

`;
  // Coach infrastructure: PLACES_CHIP_I18N, config caches, purchase patterns, getCoachConfig
  // Skip duplicate reverseGeocode/forwardGeocode (L3099-3160) — use geo.js
  // Start at L3161 (PLACES_CHIP_I18N)
  // Actually we need to grab from L3079 for any comments, but skip the geocode functions
  
  // First grab the constants/caches that are NOT in geo.js (L3079-3098 are comments + cache vars that are duplicated)
  // Let's start at line where PLACES_CHIP_I18N begins
  const placesChipLine = findLine('PLACES_CHIP_I18N', 3079);
  
  // Skip geocode cache vars and functions (they're in geo.js)
  // Go from PLACES_CHIP_I18N through getCoachConfig + learning + coachRAG
  const coachInfra = extractLines(placesChipLine, 3536);
  
  // Coach RAG: retrieveCoachKnowledge
  const coachRAG = extractLines(3699, 3812);
  
  // dateCoachChat + getCoachHistory + deleteCoachMessage  
  const coachMain = extractLines(3813, 5481);
  
  // getRealtimeCoachTips (at end of file)
  const coachTips = extractLines(7548, total);
  
  writeModule(path.join(LIB, 'coach.js'),
    header +
    '// --- Coach infrastructure ---\n' + coachInfra + '\n\n' +
    '// --- Coach RAG ---\n' + coachRAG + '\n\n' +
    '// --- Coach main functions ---\n' + coachMain + '\n\n' +
    '// --- Realtime coach tips ---\n' + coachTips + '\n');
})();

