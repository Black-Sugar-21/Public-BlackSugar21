#!/usr/bin/env node
/**
 * Modularization script for index.original.js → lib/ modules
 * 
 * Reads the monolithic file and creates separate module files.
 * Each module gets proper require headers and exports.
 * 
 * Usage: node scripts/modularize.js
 */

const fs = require('fs');
const path = require('path');

const SRC = path.join(__dirname, '..', 'index.original.js');
const LIB = path.join(__dirname, '..', 'lib');

// Read all lines (1-indexed in config, 0-indexed in array)
const allLines = fs.readFileSync(SRC, 'utf-8').split('\n');
const total = allLines.length;

function extractLines(startLine, endLine) {
  // startLine and endLine are 1-indexed inclusive
  return allLines.slice(startLine - 1, endLine).join('\n');
}

// Find the line number where a pattern first appears at/after startLine
function findLine(pattern, startLine = 1) {
  const regex = typeof pattern === 'string' ? new RegExp(pattern) : pattern;
  for (let i = startLine - 1; i < allLines.length; i++) {
    if (regex.test(allLines[i])) return i + 1; // return 1-indexed
  }
  return -1;
}

// Find the line before the next exports.XXX or function/const/async definition
function findEndOfBlock(startLine) {
  // Walk forward from startLine looking for the next top-level declaration
  for (let i = startLine; i < allLines.length; i++) {
    const line = allLines[i];
    if (i === startLine - 1) continue; // skip start line
    if (/^exports\./.test(line) || 
        /^function /.test(line) || 
        /^async function /.test(line) ||
        /^const .* = (?:onCall|onDocumentCreated|onObjectFinalized|onSchedule|onDocumentUpdated)/.test(line) ||
        /^\/\/ ={5,}/.test(line) || // section dividers
        /^\/\*\*/.test(line) && i > startLine + 2) { // JSDoc of next block
      return i; // 1-indexed line BEFORE this one
    }
  }
  return allLines.length;
}

function writeModule(filePath, content) {
  fs.writeFileSync(filePath, content, 'utf-8');
  const lines = content.split('\n').length;
  console.log(`  ✅ ${path.basename(filePath)} (${lines} lines)`);
}

// ============================================================
// MODULE DEFINITIONS
// ============================================================

console.log('\n🔧 Modularizing index.original.js → lib/\n');

// ============================================================
// 1. discovery.js (L181-473)
// ============================================================
(() => {
  const header = `'use strict';
const { onCall } = require('firebase-functions/v2/https');
const admin = require('firebase-admin');
const { haversineDistanceKm, encodeGeohash, precisionForRadius, normalizeLongitude, queryBoundsForRadius, calcAge } = require('./geo');

`;
  // L161-180 are just comments/blank before the export
  const code = extractLines(161, 474);
  writeModule(path.join(LIB, 'discovery.js'), header + code + '\n');
})();

