rules_version = '2';

// Firebase Storage Security Rules — Black Sugar 21
// Paths usados por Android y iOS:
//   - users/{userId}/{fileName}          → fotos de perfil (full + thumb)
//   - stories/{matchId}/{storyId}.jpg    → stories de chat (efímeras de match)
//   - stories/personal_stories/{uid}/... → stories personales
//   - ephemeral_photos/{matchId}/{id}.jpg→ fotos efímeras de chat

service firebase.storage {
  match /b/{bucket}/o {

    // ──────────────────────────────────────────────────────────────────
    // 1. Fotos de perfil: users/{userId}/{fileName}
    //    • Lectura: cualquier usuario autenticado (para ver fotos en la app)
    //    • Escritura: solo el propietario autenticado
    //    • Tamaño máximo: 10 MB (lo que comprime la app de 20 MB max)
    // ──────────────────────────────────────────────────────────────────
    match /users/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ──────────────────────────────────────────────────────────────────
    // 2. Stories de chat: stories/{matchId}/{storyId}.jpg
    //    • Lectura: SOLO miembros del match. Previamente cualquier usuario
    //      autenticado podía descargar con el matchId (baja entropía: concat
    //      determinístico de uids).
    //    • Escritura/Eliminación: SOLO miembros del match.
    //    • Tamaño máximo: 5 MB
    // ──────────────────────────────────────────────────────────────────
    match /stories/{matchId}/{storyId} {
      allow read: if request.auth != null
                  && firestore.get(/databases/(default)/documents/matches/$(matchId))
                       .data.usersMatched.hasAny([request.auth.uid]);
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && firestore.get(/databases/(default)/documents/matches/$(matchId))
                        .data.usersMatched.hasAny([request.auth.uid]);
      allow delete: if request.auth != null
                    && firestore.get(/databases/(default)/documents/matches/$(matchId))
                         .data.usersMatched.hasAny([request.auth.uid]);
    }

    // ──────────────────────────────────────────────────────────────────
    // 3. Stories personales: stories/personal_stories/{senderId}/{fileName}
    //    • Lectura: cualquier usuario autenticado (stories públicas entre users)
    //    • Escritura: solo el propietario
    //    • Tamaño máximo: 5 MB
    // ──────────────────────────────────────────────────────────────────
    match /stories/personal_stories/{senderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == senderId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && request.auth.uid == senderId;
    }

    // ──────────────────────────────────────────────────────────────────
    // 4. Fotos efímeras: ephemeral_photos/{matchId}/{photoId}.jpg
    //    • Lectura: SOLO miembros del match (previamente cualquier auth user
    //      podía descargar adivinando matchId + photoId).
    //    • Escritura/Eliminación: SOLO miembros del match.
    // ──────────────────────────────────────────────────────────────────
    match /ephemeral_photos/{matchId}/{photoId} {
      allow read: if request.auth != null
                  && firestore.get(/databases/(default)/documents/matches/$(matchId))
                       .data.usersMatched.hasAny([request.auth.uid]);
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && firestore.get(/databases/(default)/documents/matches/$(matchId))
                        .data.usersMatched.hasAny([request.auth.uid]);
      allow delete: if request.auth != null
                    && firestore.get(/databases/(default)/documents/matches/$(matchId))
                         .data.usersMatched.hasAny([request.auth.uid]);
    }

    // ──────────────────────────────────────────────────────────────────
    // 5. Temporales de validación: temp_validations/{uuid}.jpg
    //    Usadas por ImageValidationService antes de llamar validateProfileImage.
    //    SECURITY: previamente dos reglas solapadas — la primera con size/type
    //    check y la segunda abierta a cualquier auth user — la segunda ganaba
    //    para read/delete. Ahora consolidadas en un solo bloque con size/type
    //    check consistente y delete/read limitados a auth (CF y cliente dueño).
    //    TODO(prod-hardening): migrar clientes a temp_validations/{uid}/{uuid}
    //    para scope estricto por owner; por ahora el vector residual es que
    //    otro auth user borre uploads en vuelo — mitigado por el TTL corto del
    //    flow (upload → CF → delete en <5s).
    // ──────────────────────────────────────────────────────────────────
    match /temp_validations/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────────────────────────
    // 6. Temporales de moderación: temp_moderation/{uuid}.jpg
    //    Misma estructura que temp_validations. Consolidación de reglas
    //    duplicadas (write con size/type + delete abierto) en un solo bloque.
    // ──────────────────────────────────────────────────────────────────
    match /temp_moderation/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────────────────────────
    // 7. Denegar todo lo demás
    // ──────────────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
