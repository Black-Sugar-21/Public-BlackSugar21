rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- LIKES ---
    // Un usuario solo puede leer/escribir sus propios likes
    match /likes/{likeId} {
      allow read, write: if request.auth != null &&
        (likeId.split('_')[0] == request.auth.uid || likeId.split('_')[1] == request.auth.uid);
    }

    // --- MATCHES ---
    // Solo los usuarios involucrados pueden leer el match
    match /matches/{matchId} {
      allow read: if request.auth != null &&
   		 request.auth.uid in resource.data.usersMatched;

      // Permitir crear match si el usuario autenticado está en usersMatched
  		allow create: if request.auth != null &&
            request.auth.uid in request.resource.data.usersMatched;

      // Permitir actualizar match (para lastMessageTime, etc.)
      // SECURITY: freeze immutable match identity fields (usersMatched,
      // userTypesAtMatch, createdAt). Previously an attacker in the match
      // could flip `userTypesAtMatch[otherUid]` to block the other user
      // from sending the first message, or remove the other uid entirely.
      allow update: if request.auth != null &&
            request.auth.uid in resource.data.usersMatched &&
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(
              ['usersMatched', 'userTypesAtMatch', 'createdAt']
            );

      // No permitir eliminar
      allow delete: if false;

      // Subcolección de MESSAGES dentro de cada match
      match /messages/{messageId} {
        // Los participantes del match pueden leer mensajes
        allow read: if request.auth != null &&
              request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.usersMatched;

        // Helper function: obtener userType ORIGINAL del remitente (en el momento del match)
        function getSenderTypeAtMatch() {
          let matchData = get(/databases/$(database)/documents/matches/$(matchId)).data;
          return matchData.keys().hasAny(['userTypesAtMatch'])
            ? matchData.userTypesAtMatch[request.auth.uid]
            : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType;
        }

        // Helper function: verificar si el match tiene messageCount > 0
        function hasExistingMessages() {
          let matchData = get(/databases/$(database)/documents/matches/$(matchId)).data;
          return matchData.keys().hasAny(['messageCount']) && matchData.messageCount > 0;
        }

        // Regla de creación de mensajes — validación reforzada:
        // - senderId == caller (previene suplantación)
        // - timestamp == request.time (previene backdating)
        // - cuerpo del mensaje limitado a 4000 caracteres (anti-abuse)
        // - receiverId != senderId (previene chat consigo mismo)
        allow create: if request.auth != null &&
              request.auth.uid == request.resource.data.senderId &&
              request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.usersMatched &&
              request.resource.data.get('receiverId', '') != request.auth.uid &&
              (!request.resource.data.keys().hasAny(['message']) ||
               request.resource.data.message is string &&
               request.resource.data.message.size() <= 4000) &&
              // VALIDACIÓN PRIMER MENSAJE: Solo usuarios que eran SUGAR_DADDY/MOMMY al hacer match pueden iniciar
              (
                hasExistingMessages() ||
                getSenderTypeAtMatch() == 'SUGAR_DADDY' ||
                getSenderTypeAtMatch() == 'SUGAR_MOMMY' ||
                (!get(/databases/$(database)/documents/matches/$(matchId)).data.keys().hasAny(['userTypesAtMatch']) &&
                 (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'SUGAR_DADDY' ||
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'SUGAR_MOMMY'))
              );

        // Update: el remitente actualiza carga de fotos efímeras; cualquier participante marca viewedBy
        allow update: if request.auth != null &&
              request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.usersMatched &&
              (
                (request.auth.uid == resource.data.senderId &&
                 request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uploadProgress', 'photoUrl', 'isUploading'])) ||
                (resource.data.get('isEphemeral', false) == true &&
                 request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy']))
              );

        allow delete: if false;
      }
    }

    // --- USERS ---
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles
      allow read: if request.auth != null;

      // Crear: solo el propio usuario puede crear su doc (con validaciones de rango básicas)
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        (!request.resource.data.keys().hasAny(['latitude']) ||
         (request.resource.data.latitude >= -90 && request.resource.data.latitude <= 90)) &&
        (!request.resource.data.keys().hasAny(['longitude']) ||
         (request.resource.data.longitude >= -180 && request.resource.data.longitude <= 180)) &&
        (!request.resource.data.keys().hasAny(['maxDistance']) ||
         (request.resource.data.maxDistance >= 1 && request.resource.data.maxDistance <= 500));

      // UPDATE: solo el propio usuario y SOLO campos no privilegiados.
      // SECURITY: previamente un usuario podía auto-promoverse escribiendo
      //   isReviewer=true, isAdmin=true, userType='SUGAR_DADDY', verified=true,
      //   premium=true, coachMessagesRemaining=9999, accountStatus='active', etc.
      // Todos esos campos ahora están BLOQUEADOS — solo el admin SDK (CF) los escribe.
      allow update: if request.auth != null &&
        request.auth.uid == userId &&
        // Rango de latitud/longitud/maxDistance si se escriben
        (!request.resource.data.keys().hasAny(['latitude']) ||
         (request.resource.data.latitude >= -90 && request.resource.data.latitude <= 90)) &&
        (!request.resource.data.keys().hasAny(['longitude']) ||
         (request.resource.data.longitude >= -180 && request.resource.data.longitude <= 180)) &&
        (!request.resource.data.keys().hasAny(['maxDistance']) ||
         (request.resource.data.maxDistance >= 1 && request.resource.data.maxDistance <= 500)) &&
        // Bloquear escritura de campos privilegiados / de-servidor
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'isReviewer', 'isAdmin', 'isTest', 'userType', 'userTypeAtSignup',
          'verified', 'premium', 'accountStatus',
          'coachMessagesRemaining', 'coachMessagesLastReset',
          'superLikesRemaining', 'superLikesLastReset',
          'dailyLikesRemaining', 'lastLikeResetDate',
          'safetyScore', 'safetyScoreLastUpdate',
          'simulationsRemaining', 'multiverseRemaining',
          'reportCount', 'reportsAgainstCount',
          'createdAt', 'moderationHistory',
          'stripeCustomerId', 'stripeSubscriptionId'
        ]);

      // Subcolección LIKED — READ solo propietario (previene enumeración del grafo de likes)
      match /liked/{likedUserId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcolección PASSED: solo propietario
      match /passed/{passedUserId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcolección SWIPES: solo propietario
      match /swipes/{swipedUserId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcolección SUPERLIKED — READ solo propietario (previene enumeración del grafo de superLikes)
      match /superLiked/{superLikedUserId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcolección COMPATIBILITY_SCORES: solo propietario puede leer
      match /compatibility_scores/{scoreId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Subcolección COACH CHAT: historial de simulaciones + mensajes coach.
      // Tanto cliente (iOS/Android) como CF (admin SDK) pueden escribir aquí.
      //
      // Schema validation 2026-04-25 (audit Round-N): cap size + estructura.
      // Note 2026-04-25 (rules hotfix): clientes iOS/Android persisten respuestas
      // del CF localmente con sender='coach' (≥10 sitios en cada platform), p.ej.:
      //   - Coach reply tras dateCoachChat
      //   - Multi-universe result tras simulateMultiUniverse
      //   - Situation approaches tras simulateSituation
      //   - Date debrief, scorecard, error messages
      // Bloquear sender='coach' rompió esos flujos. Trade-off: el "prompt
      // injection" theoretical es self-targeting (el usuario solo manipula
      // SU propio contexto del coach — no afecta otros usuarios) y ya tiene
      // límites server-side: dateCoachChat usa rate limit + lee historia con
      // length cap (300 chars per msg en context window) + Gemini safety.
      // Mantenemos el size cap (8KB) y bloqueamos updates al sender/message.
      match /coachChat/{messageId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Create: caller debe ser dueño + tamaño limitado + sender entre allowed.
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.sender in ['user', 'coach', 'system']
          && (
            // sender='user' → senderId opcional pero debe coincidir con caller
            request.resource.data.sender != 'user'
            || (request.resource.data.senderId == null || request.resource.data.senderId == userId)
          )
          && (
            // message field: o no existe (sim payloads) o es string ≤ 8KB
            !('message' in request.resource.data)
            || (request.resource.data.message is string && request.resource.data.message.size() <= 8000)
          );
        // Update: solo el propio user puede tocar campos no-críticos (ej. read flag).
        // Bloquea la mutación de sender/message/timestamp para evitar tampering.
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.sender == resource.data.sender
          && (
            !('message' in resource.data)
            || request.resource.data.message == resource.data.message
          )
          && (
            !('timestamp' in resource.data)
            || request.resource.data.timestamp == resource.data.timestamp
          );
        // Delete: cliente puede borrar su propio mensaje (deleteCoachMessage CF
        // usa admin SDK y bypassa esto, pero swipe-to-delete UI puede borrar local).
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Rate-limit tracking (enforceAiRateLimit en shared.js) — solo admin SDK
      match /aiRateLimits/{fnName} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // CF runTransaction
      }

      // AI preferences learning: solo propietario lee, solo CF escribe
      match /aiPreferences/{prefId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // --- PENDING NOTIFICATIONS ---
    // SECURITY: validar senderId == caller y whitelist de keys. Previamente
    // un atacante podía crear payloads arbitrarios y el scheduled processor
    // los entregaba como push trusted.
    match /pendingNotifications/{notificationId} {
      allow create: if request.auth != null &&
        request.resource.data.get('senderId', '') == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'senderId', 'receiverId', 'type', 'title', 'body', 'data',
          'createdAt', 'processed', 'priority', 'collapseKey'
        ]);

      // Solo CF admin SDK lee/actualiza/elimina
      allow read, update, delete: if false;
    }

    // --- USER INTERACTIONS (Analytics) ---
    match /user_interactions/{interactionId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow read: if false;
      allow update, delete: if false;
    }

    // --- USER ANALYTICS (Aggregated) ---
    match /user_analytics/{userId} {
      allow read, write: if false;
    }

    // --- STORIES ---
    match /stories/{storyId} {
      // Lectura abierta: la lógica de filtrado (expiresAt, isPersonal, match membership)
      // se maneja en el cliente. Match stories no exponen datos sensibles — solo la URL
      // de Storage que ya está protegida por match-membership en storage.rules.
      allow read: if request.auth != null;

      // Crear story — validar schema + senderId == caller + cap de expiresAt a 24h
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.senderId &&
        (!request.resource.data.keys().hasAny(['expiresAt']) ||
         request.resource.data.expiresAt is timestamp);

      // Update: el propietario edita el doc completo; otros solo pueden AÑADIRSE a viewedBy.
      // SECURITY: previamente un atacante podía sobrescribir viewedBy entero con IDs
      // arbitrarios. Ahora el diff de viewedBy solo puede contener al propio uid.
      allow update: if request.auth != null &&
        (
          request.auth.uid == resource.data.senderId ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy']) &&
           request.resource.data.viewedBy.hasAll(resource.data.get('viewedBy', [])))
        );

      // Eliminar: solo el creador
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.senderId;
    }

    // --- INTEREST ITEMS (catálogo público) ---
    match /interestItems/{itemId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /interestCategories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // --- COACH CHATS (AI Date Coach — legacy path) ---
    match /coachChats/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // --- SYSTEM STATS (for Cloud Functions) ---
    match /system_stats/{docId} {
      allow read, write: if false;
    }

    // --- REPORTS (solo CF admin SDK lee/escribe) ---
    match /reports/{reportId} {
      allow read, write: if false;
    }

    // --- TESTER SIGNUPS (public write for beta enrollment from web) ---
    // Whitelist de campos + validación básica de schema.
    // TODO: añadir App Check enforcement en producción.
    match /testerSignups/{signupId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'platform', 'status']) &&
        request.resource.data.keys().hasOnly(['email', 'platform', 'status', 'createdAt', 'locale', 'source']) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 100 &&
        request.resource.data.status == 'pending';

      allow read, update, delete: if false;
    }

    // --- COACH KNOWLEDGE (RAG corpus for Coach IA + multi-universe + intent classification) ---
    // Read-only via Admin SDK (Cloud Functions bypass rules).
    // Audit C 2026-04-25: previously implicitly locked by wildcard catch-all
    // below, but explicit rule documents that this collection is CF-only and
    // must NEVER accept client writes (would allow prompt-injection chunks
    // into RAG findNearest results that LLM agents consume as few-shot).
    match /coachKnowledge/{chunkId} {
      allow read, write: if false;
    }

    // --- INTENT LEARNING QUEUE (auto-learning from probe regressions) ---
    // CF-only. Probe writes high-priority candidates here when isAdviceRequest
    // misses but LLM Layer 5 corrects. Consolidator reviews + promotes verified
    // chunks to coachKnowledge. NEVER allow client writes.
    match /intentLearningQueue/{itemId} {
      allow read, write: if false;
    }

    // --- DEFAULT ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
